{
  "name": "facebook-marketplace-mcp",
  "version": "1.1.0",
  "description": "Hardened MCP server for searching Facebook Marketplace listings by query, location, and price without browser cookies or login.",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "facebook-marketplace-mcp": "dist/index.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && node scripts/clean-dist.mjs && esbuild src/index.ts --bundle --minify --platform=node --format=cjs --target=node20 --tree-shaking=true --outfile=dist/index.cjs --metafile=dist/esbuild-meta.json && node scripts/generate-third-party-notices.mjs",
    "start": "node dist/index.cjs",
    "dev": "ts-node src/index.ts",
    "test": "node scripts/smoke-test.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "facebook-marketplace",
    "secondhand",
    "local-deals",
    "ai-tools",
    "marketplace"
  ],
  "author": "Max for Zach Babiarz",
  "license": "MIT",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "20.19.32",
    "esbuild": "0.28.1",
    "fast-uri": "3.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "undici": "7.28.0"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tyvonneboykin/facebook-marketplace-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Tyvonneboykin/facebook-marketplace-mcp/issues"
  },
  "homepage": "https://github.com/Tyvonneboykin/facebook-marketplace-mcp#readme"
}
